  "keyFeatures": [
    "Standardized hardware capability API (camera.capture, radio.scan, etc.)",
    "Cloud Registry for global hardware discovery and relay",
    "Plugin-based adapter system for any hardware type",
    "Session-based exclusive hardware access with policy enforcement",
    "MCP (Model Context Protocol) integration for LLM-native agents",
    "JavaScript/TypeScript and Python SDKs",
    "Docker-based sandboxed execution",
    "Access policies with visibility controls (public, shared, private)",
    "CLI with interactive TUI and setup wizard",
    "W3C Web of Things (WoT) semantic alignment"
  ],
  "publicApiSurface": [
    "GET /v1/capabilities — list available hardware devices",
    "POST /v1/requests — reserve a hardware session",
    "POST /v1/sessions/{session_id}/execute — execute a capability",
    "POST /v1/sessions/{session_id}/execute-batch — batch execute capabilities",
    "POST /v1/sessions/{session_id}/stop — release a session",
    "POST /v1/provider/nodes/register — register/heartbeat a node",
    "GET /v1/provider/nodes/{id}/poll — long-poll for commands",
    "POST /v1/provider/nodes/results — submit execution result",
    "OahlClient (JS SDK) — local node client",
    "CloudClient (JS SDK) — cloud relay client",
    "oahl init — interactive setup wizard",
    "oahl start — start local node daemon",
    "oahl scan-ports — detect connected USB/serial devices",
    "oahl create-adapter — scaffold a new adapter",
    "oahl mcp — start MCP server for agent integration",
    "Adapter interface: initialize(), getDevices(), getCapabilities(), execute()"
  ]
}
